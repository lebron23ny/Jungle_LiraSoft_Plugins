<Window x:Class="Jungle_LS_SetDescriptionNode.Windows.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Jungle_LS_SetDescriptionNode.Windows"
             mc:Ignorable="d" 
             MaxHeight="100" MaxWidth="300"
             MinHeight="100" MinWidth="100"
             d:DesignHeight="100" d:DesignWidth="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Описание узла" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <TextBox Grid.Column="1" VerticalAlignment="Center" Text="{Binding Description}"/>

        <Button Grid.Row="1" Grid.ColumnSpan="2" Margin="2" Content="Применить" Click="Button_Click"/>
    </Grid>
</Window>
